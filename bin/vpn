#!/usr/bin/env bash

# Prompt the user for the VM IP
read -p "Enter the VM IP address: " vm_ip

# Check if input is empty
if [ -z "$vm_ip" ]; then
    echo "No IP entered. Exiting."
    exit 1
fi

# Connect via SSH using the provided IP
ssh -L 5432:localhost:5432 -J manas@"$vm_ip" -i ~/.ssh/id_rsa fista@fista.iscte-iul.pt
